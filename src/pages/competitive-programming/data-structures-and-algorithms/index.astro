---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CompetitiveProgrammingResources from '../../../features/competitive-programming/components/CompetitiveProgrammingResources.astro';
import DsaLatexContent from '../../../features/competitive-programming-dsa/components/DsaLatexContent.astro';
import {
	getDsaCategoryRecords,
	getDsaLandingSources,
	getDsaLevelTone,
	getDsaRoutePath,
} from '../../../features/competitive-programming-dsa/lib/dsa';
import { renderLatexContent } from '../../../features/competitive-programming/lib/latex-editorial';
import { withBase } from '../../../lib/paths';

const [categories, landingSources] = await Promise.all([getDsaCategoryRecords(), getDsaLandingSources()]);
const intro = renderLatexContent(landingSources.introTex, {
	headingDepthOffset: 2,
	headingSlugPrefix: 'dsa-landing',
});
const taxonomy = renderLatexContent(landingSources.taxonomyTex, {
	headingDepthOffset: 2,
	headingSlugPrefix: 'dsa-taxonomy',
});
const implementedNotes = categories.flatMap((category) => category.notes);
const levelOrder = ['basic', 'intermediate', 'advanced', 'expert'] as const;
const levelCounts = Object.fromEntries(
	levelOrder.map((level) => [level, implementedNotes.filter((note) => note.level === level).length]),
) as Record<(typeof levelOrder)[number], number>;
const noteByKey = new Map(implementedNotes.map((note) => [`${note.categorySlug}/${note.slug}`, note]));
const pickNotes = (keys: string[]) =>
	keys
		.map((key) => noteByKey.get(key))
		.filter((note): note is NonNullable<typeof note> => Boolean(note));
const startHereNotes = pickNotes([
	'fundamentals/binary-search',
	'fundamentals/prefix-sums-and-difference-arrays',
	'fundamentals/two-pointers-and-sliding-window',
	'graph-algorithms/bfs-and-dfs',
	'data-structures/fenwick-tree',
	'string-algorithms/kmp',
]);
const spotlightNotes = pickNotes([
	'data-structures/splay-tree',
	'data-structures/link-cut-tree',
	'graph-algorithms/heavy-light-decomposition',
	'dynamic-programming/convex-hull-trick',
	'number-theory/ntt',
]);
const learningPath = [
	{
		title: 'Start here',
		description: 'Learn the low-friction patterns first: monotone search, prefix preprocessing, window scans, and basic traversal.',
		notes: 'Binary Search, Prefix Sums and Difference Arrays, Two Pointers and Sliding Window, BFS and DFS',
	},
	{
		title: 'Build fluency',
		description: 'Add the first reusable data structures and string baselines once the array and graph patterns feel routine.',
		notes: 'Fenwick Tree, Segment Tree, Disjoint Set Union, KMP, Z-Function, Topological Sort',
	},
	{
		title: 'Push into advanced',
		description: 'This is where tree queries, heavier DP, and flow or number-theory machinery start paying off.',
		notes: 'Lazy Segment Tree, Sparse Table, Knapsack, Tree DP, Dijkstra, Lowest Common Ancestor, Dinic, NTT',
	},
	{
		title: 'Save for last',
		description: 'Keep the amortized and pointer-heavy machinery for after the more standard contest baselines are stable.',
		notes: 'Heavy-Light Decomposition, Convex Hull Trick, Splay Tree, Link-Cut Tree, Min-Cost Max-Flow',
	},
];
const guidedTracks = [
	{
		title: 'Core first',
		description: 'Use this if the goal is broad contest fluency before specializing. It stays close to the patterns that appear in array, graph, and prefix-processing problems.',
		notes: pickNotes([
			'fundamentals/binary-search',
			'advanced-tricks/binary-search-on-answer',
			'fundamentals/prefix-sums-and-difference-arrays',
			'fundamentals/two-pointers-and-sliding-window',
			'fundamentals/coordinate-compression',
			'data-structures/fenwick-tree',
			'graph-algorithms/bfs-and-dfs',
		]),
	},
	{
		title: 'Graph path',
		description: 'Follow this route if tree structure, connectivity, and path queries are the current bottleneck.',
		notes: pickNotes([
			'graph-algorithms/bfs-and-dfs',
			'graph-algorithms/topological-sort',
			'graph-algorithms/dijkstra',
			'graph-algorithms/minimum-spanning-tree',
			'graph-algorithms/strongly-connected-components',
			'graph-algorithms/euler-tour-technique',
			'graph-algorithms/lowest-common-ancestor',
			'graph-algorithms/centroid-decomposition',
		]),
	},
	{
		title: 'DP optimization path',
		description: 'This path is for when the recurrence is already visible and the remaining problem is state reduction or transition acceleration.',
		notes: pickNotes([
			'dynamic-programming/knapsack',
			'dynamic-programming/tree-dp',
			'dynamic-programming/monotone-queue-optimization',
			'dynamic-programming/divide-and-conquer-dp-optimization',
			'dynamic-programming/knuth-optimization',
			'dynamic-programming/convex-hull-trick',
			'dynamic-programming/rerooting-dp',
			'dynamic-programming/aliens-trick',
		]),
	},
	{
		title: 'Advanced data structures path',
		description: 'Take this when the implementation burden is acceptable and the main task is choosing the right structural invariant.',
		notes: pickNotes([
			'data-structures/fenwick-tree',
			'data-structures/segment-tree',
			'data-structures/sparse-table',
			'data-structures/ordered-set',
			'data-structures/li-chao-tree',
			'data-structures/persistent-segment-tree',
			'data-structures/dsu-rollback',
			'data-structures/wavelet-tree',
		]),
	},
	{
		title: 'Number theory path',
		description: 'This route starts from the arithmetic tools that appear everywhere, then moves into structure-heavy topics such as CRT, multiplicative functions, and primality machinery.',
		notes: pickNotes([
			'number-theory/gcd-and-extended-euclid',
			'number-theory/modular-arithmetic',
			'number-theory/modular-inverse',
			'number-theory/sieve-of-eratosthenes',
			'number-theory/prime-factorization',
			'number-theory/chinese-remainder-theorem',
			'number-theory/mobius-function',
			'number-theory/miller-rabin-and-pollard-rho',
			'number-theory/primitive-roots-and-discrete-logarithm',
		]),
	},
];
---

<BaseLayout
	title="Data Structures & Algorithms"
	description="Long-form competitive programming notes on algorithms, data structures, and advanced techniques."
>
	<section class="page-intro cp-intro">
		<span class="eyebrow">Competitive Programming</span>
		<h1>Data Structures & Algorithms</h1>
		<p>
			Long-form notes on the algorithms, data structures, and contest patterns I want to keep in a form that is still useful months later.
		</p>
		<div class="archive-summary">
			<div class="archive-summary__item">
				<strong>{implementedNotes.length}</strong>
				<span>published notes</span>
			</div>
			<div class="archive-summary__item">
				<strong>{categories.length}</strong>
				<span>categories</span>
			</div>
			<div class="archive-summary__item">
				<strong>{categories.reduce((sum, category) => sum + category.plannedTopics.length, 0)}</strong>
				<span>planned topics</span>
			</div>
			<div class="archive-summary__item">
				<strong>TeX + C++</strong>
				<span>source-first workflow</span>
			</div>
		</div>
		<div class="chip-row">
			<a class="button" href={withBase('/competitive-programming')}>All competitive programming</a>
			<a class="button button--ghost" href={withBase('/competitive-programming/icpc')}>ICPC</a>
			<a class="button button--ghost" href={withBase('/competitive-programming/ioi')}>IOI</a>
		</div>
	</section>

	<DsaLatexContent
		sectionId="overview"
		label="Overview"
		title="How This Section Is Organized"
		description="The landing note explains the scope; the taxonomy section keeps the bigger map visible."
		html={intro.html}
		rawUrl={landingSources.assetUrls.intro}
		usedFallback={intro.usedFallback}
	/>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Start Here</span>
				<h2>A practical first path</h2>
				<p>These notes form the shortest useful route into the section before the more structural topics take over.</p>
			</div>
		</div>
		<div class="track-grid">
			{
				startHereNotes.map((note) => (
					<a class="card dsa-note-card" data-tone={getDsaLevelTone(note.level)} href={withBase(getDsaRoutePath(note.categorySlug, note.slug))}>
						<span class="eyebrow">{note.level}</span>
						<h3>{note.title}</h3>
						<p>{note.summary}</p>
						<div class="card__meta">
							<span class="metric">{note.categoryTitle}</span>
							<span class="metric">{note.tags.slice(0, 2).join(' / ')}</span>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Coverage</span>
				<h2>What is already solid</h2>
				<p>The section is intentionally uneven: the counts below show where the dense reusable notes already exist and where the next pass still has room to grow.</p>
			</div>
		</div>
		<div class="archive-summary">
			<div class="archive-summary__item">
				<strong>{levelCounts.basic}</strong>
				<span>basic notes</span>
			</div>
			<div class="archive-summary__item">
				<strong>{levelCounts.intermediate}</strong>
				<span>intermediate notes</span>
			</div>
			<div class="archive-summary__item">
				<strong>{levelCounts.advanced}</strong>
				<span>advanced notes</span>
			</div>
			<div class="archive-summary__item">
				<strong>{levelCounts.expert}</strong>
				<span>expert notes</span>
			</div>
		</div>
		<div class="chip-row">
			{
				categories.map((category) => (
					<span class="chip">
						{category.title}: {category.noteCount} complete / {category.plannedTopics.length} planned
					</span>
				))
			}
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Categories</span>
				<h2>Browse by technique family</h2>
				<p>Each category page now shows finished notes, planned topics, recommended order, and level distribution, so it is easier to decide whether to revise breadth-first or go deep on one branch.</p>
			</div>
		</div>
		<div class="track-grid">
			{
				categories.map((category, index) => {
					const categoryLevels = levelOrder.map(
						(level) => `${implementedNotes.filter((note) => note.categorySlug === category.slug && note.level === level).length} ${level}`,
					);
					return (
					<a
						class="card track-card dsa-track-card"
						data-tone={index % 3 === 0 ? 'cool' : index % 3 === 1 ? 'olive' : 'warm'}
						href={withBase(getDsaRoutePath(category.slug))}
					>
						<span class="track-card__index">0{index + 1}</span>
						<span class="eyebrow">{category.title}</span>
						<h3>{category.noteCount} published note{category.noteCount === 1 ? '' : 's'}</h3>
						<p>{category.longDescription}</p>
						<span class="track-card__link">Open {category.title}</span>
						<div class="card__meta">
							<span class="metric">{category.plannedTopics.length} planned</span>
							<span class="metric">{categoryLevels.join(' / ')}</span>
						</div>
					</a>
					);
				})
			}
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Learning Path</span>
				<h2>One reasonable order to learn this</h2>
				<p>The notes are cross-linked by topic, but this order keeps the prerequisites and implementation burden under control.</p>
			</div>
		</div>
		<div class="cp-year-grid">
			{
				learningPath.map((stage, index) => (
					<article class="cp-year-card cp-year-card--browse">
						<div class="cp-year-card__topline">
							<div>
								<strong>0{index + 1}</strong>
								<span>{stage.title}</span>
							</div>
							<span class="chip" data-tone={index < 2 ? 'olive' : index === 2 ? 'warm' : 'expert'}>
								{index < 2 ? 'Core' : index === 2 ? 'Advanced' : 'Expert'}
							</span>
						</div>
						<p class="cp-year-card__summary">{stage.description}</p>
						<p class="cp-content__notice">{stage.notes}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Learning Routes</span>
				<h2>Choose a path, not just a topic</h2>
				<p>These routes are meant to reduce thrashing. Each one keeps related ideas close enough that implementation habits carry over from note to note.</p>
			</div>
		</div>
		<div class="cp-year-grid">
			{
				guidedTracks.map((track, index) => (
					<article class="cp-year-card cp-year-card--browse">
						<div class="cp-year-card__topline">
							<div>
								<strong>0{index + 1}</strong>
								<span>{track.title}</span>
							</div>
							<span class="chip" data-tone={index % 4 === 0 ? 'olive' : index % 4 === 1 ? 'cool' : index % 4 === 2 ? 'warm' : 'expert'}>
								{track.notes.length} notes
							</span>
						</div>
						<p class="cp-year-card__summary">{track.description}</p>
						<p class="cp-content__notice">{track.notes.map((note) => note.title).join(', ')}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-panel section-panel--signal">
		<div class="section-heading">
			<div>
				<span class="section-label">Published notes</span>
				<h2>Current note library</h2>
				<p>The first pass focuses on notes I expect to reuse often in contest prep, implementation review, and post-contest study.</p>
			</div>
		</div>
		<div class="signal-grid">
			{
				implementedNotes.map((note, index) => (
					<a class="signal-card dsa-note-card" data-tone={getDsaLevelTone(note.level)} href={withBase(getDsaRoutePath(note.categorySlug, note.slug))}>
						<span class="signal-card__index">0{index + 1}</span>
						<div>
							<span class="eyebrow">{note.categoryTitle}</span>
							<h3>{note.title}</h3>
							<p>{note.summary}</p>
						</div>
						<div class="signal-card__meta">
							<span class="metric">{note.level}</span>
							<span class="metric">{note.tags.slice(0, 2).join(' / ')}</span>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-panel section-panel--signal">
		<div class="section-heading">
			<div>
				<span class="section-label">Advanced Spotlight</span>
				<h2>Save these for when the basics feel routine</h2>
				<p>These notes are the ones most likely to repay a slower read: they unlock bigger structures, stronger reductions, or heavier implementation patterns.</p>
			</div>
		</div>
		<div class="signal-grid">
			{
				spotlightNotes.map((note, index) => (
					<a class="signal-card dsa-note-card" data-tone={getDsaLevelTone(note.level)} href={withBase(getDsaRoutePath(note.categorySlug, note.slug))}>
						<span class="signal-card__index">0{index + 1}</span>
						<div>
							<span class="eyebrow">{note.categoryTitle}</span>
							<h3>{note.title}</h3>
							<p>{note.summary}</p>
						</div>
						<div class="signal-card__meta">
							<span class="metric">{note.level}</span>
							<span class="metric">{note.tags.slice(0, 2).join(' / ')}</span>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<DsaLatexContent
		sectionId="taxonomy"
		label="Taxonomy"
		title="Controlled Topic Map"
		description="This is the stable topic map for the section: some entries already have full notes, others are intentionally marked as planned."
		html={taxonomy.html}
		rawUrl={landingSources.assetUrls.taxonomy}
		usedFallback={taxonomy.usedFallback}
	/>

	<CompetitiveProgrammingResources
		links={[
			{ label: 'Landing TeX source', href: landingSources.assetUrls.intro, path: landingSources.sourcePaths.intro },
			{ label: 'Taxonomy TeX source', href: landingSources.assetUrls.taxonomy, path: landingSources.sourcePaths.taxonomy },
		]}
	/>
</BaseLayout>
