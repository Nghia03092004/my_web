---
import { promises as fs } from 'node:fs';
import path from 'node:path';
import { pathToFileURL } from 'node:url';

import BaseLayout from '../../layouts/BaseLayout.astro';
import {
	getDsaCategoryRecords,
	getDsaNoteRecords,
	getDsaRoutePath,
} from '../../features/competitive-programming-dsa/lib/dsa';
import { formatDate } from '../../lib/content';
import { withBase } from '../../lib/paths';
import {
	getCompetitiveProgrammingRecords,
	getCompetitiveProgrammingTrackSummaries,
	getCompetitiveProgrammingYearGroups,
} from '../../features/competitive-programming/lib/competitive-programming';
import {
	getCsesArchiveSummary,
	getCsesProblemRecords,
} from '../../features/competitive-programming-cses/lib/cses';

function toDate(value: Date | string | undefined) {
	if (!value) {
		return undefined;
	}

	const normalized = value instanceof Date ? value : new Date(value);
	return Number.isNaN(normalized.getTime()) ? undefined : normalized;
}

function compareDates(left: Date | string | undefined, right: Date | string | undefined) {
	return (toDate(right)?.getTime() ?? 0) - (toDate(left)?.getTime() ?? 0);
}

async function loadOptionalLeetcodeArchive() {
	const leetcodeLibPath = path.resolve(
		process.cwd(),
		'src',
		'features',
		'competitive-programming-leetcode',
		'lib',
		'leetcode.ts',
	);

	try {
		await fs.access(leetcodeLibPath);
		const module = await import(pathToFileURL(leetcodeLibPath).href);
		const [summary, records] = await Promise.all([
			module.getLeetcodeArchiveSummary(),
			module.getLeetcodeProblemRecords(),
		]);

		return {
			enabled: true,
			summary,
			records,
		};
	} catch {
		return {
			enabled: false,
			summary: {
				entryCount: 0,
				activeCategoryCount: 0,
			},
			records: [] as Array<{
				categorySlug: string;
				categoryTitle: string;
				slug: string;
				title: string;
				summary: string;
				difficulty: string;
				updated: Date | string;
			}>,
		};
	}
}

async function loadOptionalCodeforces3500Archive() {
	const codeforcesLibPath = path.resolve(
		process.cwd(),
		'src',
		'features',
		'competitive-programming-codeforces',
		'lib',
		'codeforces3500.ts',
	);

	try {
		await fs.access(codeforcesLibPath);
		const module = await import(pathToFileURL(codeforcesLibPath).href);
		const [summary, records] = await Promise.all([
			module.getCodeforces3500ArchiveSummary(),
			module.getCodeforces3500ProblemRecords(),
		]);

		return {
			enabled: true,
			summary,
			records,
		};
	} catch {
		return {
			enabled: false,
			summary: {
				entryCount: 0,
			},
			records: [] as Array<{
				slug: string;
				contestLabel: string;
				title: string;
				summary: string;
				updated: Date | string;
			}>,
		};
	}
}

const [
	summaries,
	allRecords,
	optionalLeetcode,
	optionalCodeforces3500,
	csesSummary,
	csesRecords,
	icpcYears,
	ioiYears,
	dsaCategories,
	dsaNotes,
] = await Promise.all([
	getCompetitiveProgrammingTrackSummaries(),
	getCompetitiveProgrammingRecords(),
	loadOptionalLeetcodeArchive(),
	loadOptionalCodeforces3500Archive(),
	getCsesArchiveSummary(),
	getCsesProblemRecords(),
	getCompetitiveProgrammingYearGroups('icpc'),
	getCompetitiveProgrammingYearGroups('ioi'),
	getDsaCategoryRecords(),
	getDsaNoteRecords(),
]);
const [icpcSummary, ioiSummary] = summaries;
const leetcodeSummary = optionalLeetcode.summary;
const leetcodeRecords = optionalLeetcode.records;
const codeforces3500Summary = optionalCodeforces3500.summary;
const codeforces3500Records = optionalCodeforces3500.records;
const totalEntries =
	summaries.reduce((sum, summary) => sum + summary.entryCount, 0) +
	leetcodeSummary.entryCount +
	csesSummary.entryCount +
	codeforces3500Summary.entryCount;
const latestUpdated = [
	...allRecords.map((record) => record.updated),
	...leetcodeRecords.map((record) => record.updated),
	...csesRecords.map((record) => record.updated),
	...codeforces3500Records.map((record) => record.updated),
	...dsaNotes.map((note) => note.updated),
]
	.map((value) => toDate(value))
	.filter((value): value is Date => Boolean(value))
	.sort((left, right) => compareDates(left, right))[0];
const featuredYears = [...icpcYears, ...ioiYears]
	.sort((left, right) => {
		if (left.year !== right.year) {
			return right.year - left.year;
		}

		return left.track.localeCompare(right.track);
	})
	.slice(0, 6);
const latestEntries = [
	...allRecords.map((record) => ({
		href: withBase(`/competitive-programming/${record.track}/${record.year}/${record.slug}`),
		tone: record.track === 'icpc' ? 'warm' : 'cool',
		eyebrow: `${record.track.toUpperCase()} ${record.year}`,
		title: record.displayTitle,
		description: record.statementPreview ?? record.description,
		updated: toDate(record.updated) ?? new Date(0),
		detail: record.hasStatementText ? 'statement + editorial + code' : 'editorial + code',
	})),
	...csesRecords.map((record) => ({
		href: withBase(`/competitive-programming/cses/${record.categorySlug}/${record.slug}`),
		tone: 'cool',
		eyebrow: `CSES ${record.categoryTitle}`,
		title: record.title,
		description: record.summary,
		updated: toDate(record.updated) ?? new Date(0),
		detail: 'official link + editorial + code',
	})),
	...leetcodeRecords.map((record) => ({
		href: withBase(`/competitive-programming/leetcode/${record.categorySlug}/${record.slug}`),
		tone: record.difficulty === 'Easy' ? 'olive' : record.difficulty === 'Medium' ? 'cool' : 'expert',
		eyebrow: `LeetCode ${record.categoryTitle}`,
		title: record.title,
		description: record.summary,
		updated: toDate(record.updated) ?? new Date(0),
		detail: `${record.difficulty} + pattern write-up + code`,
	})),
	...(optionalCodeforces3500.enabled
		? codeforces3500Records.map((record) => ({
				href: withBase(`/competitive-programming/codeforces/3500/${record.slug}`),
				tone: 'warm',
				eyebrow: `CF ${record.contestLabel}`,
				title: record.title,
				description: record.summary,
				updated: toDate(record.updated) ?? new Date(0),
				detail: 'official link + deep editorial + code',
			}))
		: []),
]
	.sort((left, right) => compareDates(left.updated, right.updated))
	.slice(0, 6);
const publicBranches = [
	{
		key: 'icpc',
		href: withBase('/competitive-programming/icpc'),
		tone: 'warm',
		indexLabel: '01',
		eyebrow: icpcSummary.label,
		title: icpcSummary.longLabel,
		description: `${icpcSummary.entryCount} problems across ${icpcSummary.yearCount} years. ${icpcSummary.statementTextCount} statement texts and ${icpcSummary.statementPdfCount} PDFs are mirrored in the archive.`,
		linkLabel: `Browse ${icpcSummary.label}`,
	},
	{
		key: 'ioi',
		href: withBase('/competitive-programming/ioi'),
		tone: 'cool',
		indexLabel: '02',
		eyebrow: ioiSummary.label,
		title: ioiSummary.longLabel,
		description: `${ioiSummary.entryCount} problems across ${ioiSummary.yearCount} years. Each task page centers the write-up and code.`,
		linkLabel: `Browse ${ioiSummary.label}`,
	},
	...(optionalLeetcode.enabled
		? [
				{
					key: 'leetcode',
					href: withBase('/competitive-programming/leetcode'),
					tone: 'olive',
					indexLabel: '03',
					eyebrow: 'LeetCode',
					title: 'LeetCode Solutions',
					description: `${leetcodeSummary.entryCount} curated interview-focused solutions across ${leetcodeSummary.activeCategoryCount} active categories, with pattern recognition, original summaries, and clean C++ implementations.`,
					linkLabel: 'Browse LeetCode',
				},
			]
		: []),
	{
		key: 'dsa',
		href: withBase(getDsaRoutePath()),
		tone: 'olive',
		indexLabel: optionalLeetcode.enabled ? '04' : '03',
		eyebrow: 'DSA',
		title: 'Data Structures & Algorithms',
		description: `${dsaNotes.length} published notes across ${dsaCategories.length} categories, all kept in TeX plus standalone C++ so the write-up and implementation stay editable.`,
		linkLabel: 'Browse DSA notes',
	},
	{
		key: 'cses',
		href: withBase('/competitive-programming/cses'),
		tone: 'cool',
		indexLabel: optionalLeetcode.enabled ? '05' : '04',
		eyebrow: 'CSES',
		title: 'CSES Problem Set',
		description: `${csesSummary.entryCount} published solutions across ${csesSummary.categoryCount} official categories, with original summaries, rendered editorials, and exact C++ source files.`,
		linkLabel: 'Browse CSES',
	},
	...(optionalCodeforces3500.enabled
		? [
				{
					key: 'codeforces-3500',
					href: withBase('/competitive-programming/codeforces/3500'),
					tone: 'warm',
					indexLabel: optionalLeetcode.enabled ? '06' : '05',
					eyebrow: 'CODEFORCES',
					title: 'Codeforces 3500+ Problems',
					description: `${codeforces3500Summary.entryCount} published deep dives for very hard Codeforces problems, each kept intentionally small-batch and source-first.`,
					linkLabel: 'Browse Codeforces 3500+',
				},
			]
		: []),
];
const archiveDescription =
	optionalLeetcode.enabled && optionalCodeforces3500.enabled
		? 'This section has six public branches: the ICPC archive, the IOI archive, the LeetCode archive, the CSES archive, the Codeforces 3500+ archive, and a growing Data Structures & Algorithms notebook. The contest pages keep explanations and code tied to source files; the LeetCode branch emphasizes interview-facing pattern recognition; the DSA branch keeps reusable ideas in longer note form.'
		: optionalLeetcode.enabled
			? 'This section has five public branches: the ICPC archive, the IOI archive, the LeetCode archive, the CSES archive, and a growing Data Structures & Algorithms notebook. The contest pages keep explanations and code tied to source files; the LeetCode branch emphasizes interview-facing pattern recognition; the DSA branch keeps reusable ideas in longer note form.'
			: optionalCodeforces3500.enabled
				? 'This section has five public branches: the ICPC archive, the IOI archive, the CSES archive, the Codeforces 3500+ archive, and a growing Data Structures & Algorithms notebook. The contest pages keep explanations and code tied to source files; the DSA branch keeps reusable ideas in longer note form.'
				: 'This section has four public branches: the ICPC archive, the IOI archive, the CSES archive, and a growing Data Structures & Algorithms notebook. The contest pages keep explanations and code tied to source files; the DSA branch keeps reusable ideas in longer note form.';
---

<BaseLayout
	title="Competitive Programming"
	description={optionalLeetcode.enabled && optionalCodeforces3500.enabled
		? 'ICPC, IOI, LeetCode, CSES, Codeforces 3500+, and data-structures-and-algorithms notes organized for browsing, revision, and reuse.'
		: optionalLeetcode.enabled
			? 'ICPC, IOI, LeetCode, CSES, and data-structures-and-algorithms notes organized for browsing, revision, and reuse.'
			: optionalCodeforces3500.enabled
				? 'ICPC, IOI, CSES, Codeforces 3500+, and data-structures-and-algorithms notes organized for browsing, revision, and reuse.'
				: 'ICPC, IOI, CSES, and data-structures-and-algorithms notes organized for browsing, revision, and reuse.'}
>
	<section class="page-intro cp-intro">
		<span class="eyebrow">Competitive Programming</span>
		<h1>Contest archive plus long-form study notes.</h1>
		<p>{archiveDescription}</p>
		<div class="archive-summary">
			<div class="archive-summary__item">
				<strong>{totalEntries}</strong>
				<span>problem pages</span>
			</div>
			<div class="archive-summary__item">
				<strong>{dsaNotes.length}</strong>
				<span>published DSA notes</span>
			</div>
			<div class="archive-summary__item">
				<strong>{publicBranches.length}</strong>
				<span>public branches</span>
			</div>
			<div class="archive-summary__item">
				<strong>{latestUpdated ? formatDate(latestUpdated) : 'n/a'}</strong>
				<span>most recently updated page</span>
			</div>
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Branches</span>
				<h2>Start with a public branch</h2>
				<p>The contest archives browse by track/year or official category, while the DSA branch acts as a reusable knowledge base.</p>
			</div>
		</div>
		<div class="track-grid">
			{
				publicBranches.map((branch) => (
					<a
						class="card track-card"
						data-tone={branch.tone}
						href={branch.href}
					>
						<span class="track-card__index">{branch.indexLabel}</span>
						<span class="eyebrow">{branch.eyebrow}</span>
						<h3>{branch.title}</h3>
						<p>{branch.description}</p>
						<span class="track-card__link">{branch.linkLabel}</span>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Browse by year</span>
				<h2>Recent contest years</h2>
				<p>The year page is the main browsing layer: it lists the problems, resource badges, and direct links to each solution page.</p>
			</div>
		</div>

		<div class="cp-year-grid">
			{
				featuredYears.map((group) => (
					<article class="cp-year-card cp-year-card--browse">
						<div class="cp-year-card__topline">
							<div>
								<strong>{group.year}</strong>
								<span>{group.entryCount} problems</span>
							</div>
							<span class="chip" data-tone={group.track === 'icpc' ? 'warm' : 'cool'}>
								{group.track.toUpperCase()}
							</span>
						</div>
						<p class="cp-year-card__summary">
							{group.track === 'icpc'
								? `${group.statementTextCount} statement texts and ${group.statementPdfCount} PDFs are available for this year.`
								: 'Task pages are grouped here by year before you drill down into an individual problem.'}
						</p>
						<ul class="cp-year-card__list">
							{group.records.slice(0, 4).map((record) => <li>{record.displayTitle}</li>)}
						</ul>
						<div class="cp-year-card__actions">
							<a class="button" href={withBase(`/competitive-programming/${group.track}/${group.year}`)}>
								Browse {group.track.toUpperCase()} {group.year}
							</a>
							{group.packetUrl ? (
								<a class="button button--ghost" href={withBase(group.packetUrl)}>
									Contest packet
								</a>
							) : null}
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-panel section-panel--signal">
		<div class="section-heading">
			<div>
				<span class="section-label">Recent additions</span>
				<h2>Recently updated problem pages</h2>
				<p>These stay secondary to the track/year browse flow, but they are still useful when you want to see what changed most recently.</p>
			</div>
		</div>
		<div class="signal-grid">
			{
				latestEntries.map((record, index) => (
					<a
						class="signal-card"
						data-tone={record.tone}
						href={record.href}
					>
						<span class="signal-card__index">0{index + 1}</span>
						<div>
							<span class="eyebrow">{record.eyebrow}</span>
							<h3>{record.title}</h3>
							<p>{record.description}</p>
						</div>
						<div class="signal-card__meta">
							<span class="metric">{formatDate(record.updated)}</span>
							<span class="metric">{record.detail}</span>
						</div>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
